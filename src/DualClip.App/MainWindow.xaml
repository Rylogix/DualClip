<Window x:Class="DualClip.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="DualClip"
        Width="1060"
        Height="860"
        MinWidth="920"
        MinHeight="700"
        Background="#0F1318"
        Foreground="#EEF2FA"
        Icon="Assets/DualClipLogo.png"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        SourceInitialized="Window_SourceInitialized"
        StateChanged="Window_StateChanged"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0F1318" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#171C22" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1A2028" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#11161C" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#2A3340" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5C8DFF" />
        <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#233653" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#1B2B44" />
        <SolidColorBrush x:Key="TextBrush" Color="#EEF2FA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#98A7BF" />
        <SolidColorBrush x:Key="InputBrush" Color="#0D1218" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#35191E" />
        <SolidColorBrush x:Key="ErrorBorderBrush" Color="#7A3944" />
        <SolidColorBrush x:Key="ErrorTextBrush" Color="#FFBDC6" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#0D1218" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1A2028" />
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#EEF2FA" />
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#EEF2FA" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#233653" />
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#EEF2FA" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="34" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="10,0,6,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <Border Grid.Column="1"
                                            Background="{StaticResource PanelAltBrush}"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1,0,0,0"
                                            CornerRadius="0,6,6,0">
                                        <Path Width="10"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Fill="{StaticResource TextBrush}"
                                              Data="M 0 0 L 10 0 L 5 6 Z" />
                                    </Border>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding ElementName=DropDownToggle}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, ElementName=DropDownToggle}"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer Margin="2"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorHandleThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource TextBrush}"
                                BorderThickness="1"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayheadThumbStyle" TargetType="Thumb" BasedOn="{StaticResource EditorHandleThumbStyle}">
            <Setter Property="Width" Value="12" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="4" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorKeyframeThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentSurfaceBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="8" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CropCornerThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource TextBrush}"
                                BorderThickness="1"
                                CornerRadius="7" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CropEdgeThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{StaticResource AccentBrush}"
                                BorderBrush="{StaticResource TextBrush}"
                                BorderThickness="1"
                                CornerRadius="5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CropMoveThumbStyle" TargetType="Thumb">
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#18000000"
                                BorderBrush="Transparent"
                                BorderThickness="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Height="6"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Ellipse Fill="{StaticResource AccentBrush}"
                                     Stroke="{StaticResource SurfaceBrush}"
                                     StrokeThickness="1.5" />
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="{StaticResource SurfaceBrush}"
                                     Opacity="0.95" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="28">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="{StaticResource AccentMutedBrush}"
                                                  Style="{StaticResource SliderTrackButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernSliderThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="{StaticResource BorderBrushDark}"
                                                  Style="{StaticResource SliderTrackButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Track" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Padding="10,6"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="8,8,0,0">
                                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                            </Border>
                            <Border Grid.Row="1"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="0,0,8,8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MainTabRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RadioBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Setter TargetName="RadioBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RadioBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShowOnSettingsTabStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSettingsTabSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ShowOnCaptureTabStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCaptureTabSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="Padding" Value="10,5" />
        </Style>

        <Style x:Key="ClipTitleButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TimelineScrollBarTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageScrollBarTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageVerticalScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="0,2"
                                Background="{StaticResource AccentMutedBrush}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageVerticalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="14" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Margin" Value="10,2,0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Width="12"
                                    HorizontalAlignment="Center"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                                      Style="{StaticResource PageScrollBarTrackButtonStyle}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource PageVerticalScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                                      Style="{StaticResource PageScrollBarTrackButtonStyle}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource InputBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimelineScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Height" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Margin="0,2"
                                Background="{StaticResource AccentMutedBrush}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimelineHorizontalScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Height" Value="14" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Margin" Value="6,6,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Height="12"
                                    VerticalAlignment="Center"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                      Style="{StaticResource TimelineScrollBarTrackButtonStyle}" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource TimelineScrollBarThumbStyle}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand"
                                                      Style="{StaticResource TimelineScrollBarTrackButtonStyle}" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource InputBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorToolToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorSnapToggleStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="SnapBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                                <Border x:Name="SnapTrack"
                                        Grid.Column="2"
                                        Width="36"
                                        Height="20"
                                        Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <Ellipse x:Name="SnapThumb"
                                             Width="12"
                                             Height="12"
                                             Margin="3,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Fill="{StaticResource MutedTextBrush}" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SnapBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="SnapBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SnapBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SnapTrack" Property="Background" Value="{StaticResource AccentMutedBrush}" />
                                <Setter TargetName="SnapTrack" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="SnapThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="SnapThumb" Property="Margin" Value="0,0,3,0" />
                                <Setter TargetName="SnapThumb" Property="Fill" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SnapBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="ToggleShell"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="44" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  RecognizesAccessKey="True" />
                                <Border x:Name="ToggleTrack"
                                        Grid.Column="2"
                                        Width="44"
                                        Height="24"
                                        Background="{StaticResource InputBrush}"
                                        BorderBrush="{StaticResource BorderBrushDark}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Ellipse x:Name="ToggleThumb"
                                             Width="14"
                                             Height="14"
                                             Margin="4,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Fill="{StaticResource MutedTextBrush}" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleShell" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ToggleShell" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleShell" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                <Setter TargetName="ToggleShell" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ToggleTrack" Property="Background" Value="{StaticResource AccentMutedBrush}" />
                                <Setter TargetName="ToggleTrack" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="ToggleThumb" Property="Margin" Value="0,0,4,0" />
                                <Setter TargetName="ToggleThumb" Property="Fill" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleShell" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCardExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border x:Name="ExpanderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <ToggleButton x:Name="ExpanderToggleButton"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Content="{TemplateBinding Header}"
                                              Focusable="False"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="ExpanderChevron"
                                                      Width="10"
                                                      Height="6"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Fill="{StaticResource MutedTextBrush}"
                                                      Data="M 0 0 L 10 0 L 5 6 Z"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="-90" />
                                                    </Path.RenderTransform>
                                                </Path>
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ExpanderChevron" Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="ExpanderChevron" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="0" />
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Setter TargetName="ExpanderChevron" Property="Fill" Value="{StaticResource AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpanderContent"
                                                  ContentSource="Content"
                                                  Margin="0,10,0,0"
                                                  Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExpanderBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ExpanderBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InspectorLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="WindowChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeButtonBorder" Property="Background" Value="{StaticResource AccentMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeButtonBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChromeButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowChromeButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowChromeButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9C2F3B" />
                    <Setter Property="Foreground" Value="#FFF3F5" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#7F2530" />
                    <Setter Property="Foreground" Value="#FFF3F5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitleBarIconButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowChromeButtonStyle}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>

        <Style x:Key="UpdateOverlayActionPanelStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanShowUpdateOverlayActions}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UpdateOverlaySpinnerPanelStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanShowUpdateOverlaySpinner}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border x:Name="WindowFrameBorder"
            Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource BorderBrushDark}"
            BorderThickness="1"
            CornerRadius="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="WindowTitleBarBorder"
                    Grid.Row="0"
                    Padding="12,10,12,8"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="18,18,0,0">
                <Grid Height="34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.ColumnSpan="2"
                            Background="Transparent"
                            MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown" />

                    <StackPanel Grid.Column="0"
                                Margin="8,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                            <Border Width="22"
                                    Height="22"
                                    Padding="3"
                                    Background="{StaticResource AccentMutedBrush}"
                                    CornerRadius="7">
                                <Image Source="Assets/DualClipLogo.png" Stretch="Uniform" />
                            </Border>
                            <TextBlock Margin="10,0,0,0"
                                       Height="22"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       LineHeight="22"
                                       LineStackingStrategy="BlockLineHeight"
                                       Text="DualClip" />
                        </StackPanel>
                        <Button Style="{StaticResource TitleBarIconButtonStyle}"
                                Click="OpenDiscordButton_Click"
                                ToolTip="Join Discord">
                            <Viewbox Width="16" Height="16">
                                <Grid Width="24" Height="24">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Stretch="Fill"
                                          Data="M12,2.2C8.58,2.2 5.79,3.94 4.22,6.77C3.2,8.6 2.75,10.67 2.84,12.76C2.96,15.59 4.03,18.03 6.02,19.96L6.28,20.2L9.09,18.47L8.42,17.99C7.49,17.33 6.76,16.5 6.26,15.5C7.12,16.13 8.07,16.58 9.08,16.83C10.03,17.06 11.01,17.18 12,17.18C12.99,17.18 13.97,17.06 14.92,16.83C15.93,16.58 16.88,16.13 17.74,15.5C17.24,16.5 16.51,17.33 15.58,17.99L14.91,18.47L17.72,20.2L17.98,19.96C19.97,18.03 21.04,15.59 21.16,12.76C21.25,10.67 20.8,8.6 19.78,6.77C18.21,3.94 15.42,2.2 12,2.2ZM9.46,13.92C8.54,13.92 7.8,13.07 7.8,12.01C7.8,10.95 8.54,10.1 9.46,10.1C10.37,10.1 11.12,10.95 11.12,12.01C11.12,13.07 10.37,13.92 9.46,13.92ZM14.54,13.92C13.63,13.92 12.88,13.07 12.88,12.01C12.88,10.95 13.63,10.1 14.54,10.1C15.46,10.1 16.2,10.95 16.2,12.01C16.2,13.07 15.46,13.92 14.54,13.92Z" />
                                </Grid>
                            </Viewbox>
                        </Button>
                        <TextBlock Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="&lt;- Report all bugs here" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowChromeButtonStyle}"
                                Click="MinimizeWindowButton_Click"
                                ToolTip="Minimize">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE921;" />
                        </Button>
                        <Button x:Name="ToggleMaximizeWindowButton"
                                Style="{StaticResource WindowChromeButtonStyle}"
                                Click="ToggleMaximizeWindowButton_Click"
                                ToolTip="Maximize">
                            <TextBlock x:Name="ToggleMaximizeWindowButtonGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Text="&#xE922;" />
                        </Button>
                        <Button Style="{StaticResource CloseWindowChromeButtonStyle}"
                                Click="CloseWindowButton_Click"
                                ToolTip="Close">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalFirst"
                          CanContentScroll="False">
                <ScrollViewer.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource PageVerticalScrollBarStyle}" />
                </ScrollViewer.Resources>
                <Grid Margin="18,14,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16"
                    Margin="0,0,0,12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="52"
                                Height="52"
                                Padding="8"
                                Background="{StaticResource AccentMutedBrush}"
                                CornerRadius="16">
                            <Image Source="Assets/DualClipLogo.png" Stretch="Uniform" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="DualClip" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="{Binding AppStatus}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="14,8"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="14"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#D86A6A" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                <Setter Property="Fill" Value="#47B36B" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#D86A6A" />
                                        <Setter Property="Text" Value="Clipping inactive" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                <Setter Property="Foreground" Value="#47B36B" />
                                                <Setter Property="Text" Value="Clipping active" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Padding="10" Margin="0,0,0,12" Background="{StaticResource ErrorBrush}" BorderBrush="{StaticResource ErrorBorderBrush}" BorderThickness="1" CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" Foreground="{StaticResource ErrorTextBrush}" />
            </Border>

            <Border Grid.Row="2"
                    Margin="0,0,0,12"
                    Padding="12"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="10">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Right">
                        <RadioButton GroupName="MainSections"
                                     Margin="0,0,10,0"
                                     Style="{StaticResource MainTabRadioButtonStyle}"
                                     IsChecked="{Binding IsCaptureTabSelected, Mode=TwoWay}"
                                     Content="Capture" />
                        <RadioButton GroupName="MainSections"
                                     Margin="0"
                                     Style="{StaticResource MainTabRadioButtonStyle}"
                                     IsChecked="{Binding IsSettingsTabSelected, Mode=TwoWay}"
                                     Content="Settings" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="3" Margin="0,0,0,12" Style="{StaticResource ShowOnSettingsTabStyle}" IsEnabled="{Binding CanStart}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <GroupBox Header="Monitor Nodes" Margin="0,0,8,0" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Each node is a capture target. Pick a screen, set a hotkey, and choose where that screen's clips should go." />
                            <WrapPanel Margin="0,10,0,0"
                                       HorizontalAlignment="Right">
                                <Button Margin="0,0,8,8"
                                        Padding="12,4"
                                        Click="AddMonitorNodeButton_Click"
                                        Content="Add Monitor Node" />
                                <Button Margin="0,0,0,8"
                                        Padding="12,4"
                                        Click="AutoDetectMonitorsButton_Click"
                                        Content="Auto Detect Monitors" />
                            </WrapPanel>
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding MonitorNodes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{StaticResource PanelAltBrush}"
                                            BorderBrush="{StaticResource BorderBrushDark}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Node Name" />
                                            <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,8,10" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Row="0"
                                                    Grid.Column="2"
                                                    Margin="0,0,0,10"
                                                    Padding="12,4"
                                                    Click="RemoveMonitorNodeButton_Click"
                                                    Content="Remove"
                                                    IsEnabled="{Binding DataContext.CanRemoveMonitorNodes, RelativeSource={RelativeSource AncestorType=Window}}" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Display" />
                                            <ComboBox Grid.Row="1"
                                                      Grid.Column="1"
                                                      Grid.ColumnSpan="2"
                                                      Margin="0,0,0,10"
                                                      ItemsSource="{Binding DataContext.Monitors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding SelectedMonitor}" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Hotkey" />
                                            <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" DataContext="{Binding Hotkey}">
                                                <TextBox Margin="0,0,0,10"
                                                         IsReadOnly="True"
                                                         Cursor="Hand"
                                                         Text="{Binding DisplayText, Mode=OneWay}"
                                                         PreviewMouseLeftButtonDown="HotkeyCaptureTextBox_PreviewMouseLeftButtonDown"
                                                         GotKeyboardFocus="HotkeyCaptureTextBox_GotKeyboardFocus"
                                                         LostKeyboardFocus="HotkeyCaptureTextBox_LostKeyboardFocus"
                                                         PreviewKeyDown="HotkeyCaptureTextBox_PreviewKeyDown"
                                                         PreviewKeyUp="HotkeyCaptureTextBox_PreviewKeyUp" />
                                                <DockPanel>
                                                    <TextBlock VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               Text="Click and press a combo. Backspace clears it for manual-only save."
                                                               TextWrapping="Wrap" />
                                                    <Button DockPanel.Dock="Right"
                                                            Margin="10,0,0,0"
                                                            Padding="10,4"
                                                            Click="ClearHotkeyButton_Click"
                                                            Content="Clear" />
                                                </DockPanel>
                                            </StackPanel>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Output Folder" />
                                            <TextBox Grid.Row="3"
                                                     Grid.Column="1"
                                                     Margin="0,0,8,0"
                                                     IsReadOnly="True"
                                                     Cursor="Hand"
                                                     Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                                     PreviewMouseLeftButtonDown="OutputFolderTextBox_PreviewMouseLeftButtonDown" />
                                            <Button Grid.Row="3"
                                                    Grid.Column="2"
                                                    Padding="12,4"
                                                    Click="OpenMonitorNodeOutputFolderButton_Click"
                                                    Content="Open" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="1" Header="Capture Settings" Margin="8,0,0,0" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Replay Seconds" />
                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="{Binding ReplayLengthSecondsText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="FPS Target" />
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="{Binding FpsTargetText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Clip Quality" />
                        <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" ItemsSource="{Binding VideoQualities}" SelectedItem="{Binding SelectedVideoQuality}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Audio Source" />
                        <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" ItemsSource="{Binding AudioModes}" SelectedItem="{Binding SelectedAudioMode}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,10" VerticalAlignment="Center" Text="Microphone" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  Grid.ColumnSpan="2"
                                  Margin="0,0,0,10"
                                  IsEnabled="{Binding IsMicrophoneSelectionEnabled}"
                                  ItemsSource="{Binding Microphones}"
                                  SelectedItem="{Binding SelectedMicrophone}" />

                        <StackPanel Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2">
                            <CheckBox VerticalAlignment="Center"
                                      Style="{StaticResource SettingsToggleSwitchStyle}"
                                      IsChecked="{Binding StartCaptureOnStartup}"
                                      Content="Start clipping on startup" />
                            <TextBlock Margin="2,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Begin capture automatically whenever DualClip launches."
                                       TextWrapping="Wrap" />
                            <CheckBox Margin="22,12,0,0"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource SettingsToggleSwitchStyle}"
                                      IsChecked="{Binding LaunchOnStartup}"
                                      Content="Launch DualClip on Windows startup" />
                            <TextBlock Margin="24,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Open DualClip automatically when you sign in to Windows."
                                       TextWrapping="Wrap" />
                            <Border Margin="0,12,0,0"
                                    Padding="12"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Updates" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding CurrentVersionText}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding UpdateStatusText}"
                                               TextWrapping="Wrap" />
                                    <Expander Margin="0,12,0,0"
                                              Header="{Binding UpdateNotesTitle}">
                                        <Expander.Style>
                                            <Style TargetType="Expander" BasedOn="{StaticResource SettingsCardExpanderStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasUpdateNotes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Expander.Style>
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}"
                                                   Text="{Binding UpdateNotesText}"
                                                   TextWrapping="Wrap" />
                                    </Expander>
                                    <WrapPanel Margin="0,12,0,0">
                                        <WrapPanel.Style>
                                            <Style TargetType="WrapPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowsGitHubUpdateActions}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </WrapPanel.Style>
                                        <Button Margin="0,0,8,0"
                                                Padding="12,4"
                                                Click="CheckForUpdatesButton_Click"
                                                IsEnabled="{Binding CanCheckForUpdates}"
                                                Content="Check for Updates" />
                                        <Button Padding="12,4"
                                                Click="InstallUpdateButton_Click"
                                                IsEnabled="{Binding CanInstallUpdate}"
                                                Content="{Binding InstallUpdateButtonText}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource ShowOnSettingsTabStyle}" Visibility="Collapsed" />

            <Border Grid.Row="5" Style="{StaticResource ShowOnSettingsTabStyle}" Visibility="Collapsed" />

            <StackPanel Grid.Row="6" Style="{StaticResource ShowOnCaptureTabStyle}">
                <ItemsControl ItemsSource="{Binding MonitorNodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="270"
                                    Margin="0,0,12,12"
                                    Padding="12"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrushDark}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding DisplayTitle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding SelectedMonitor.DisplayName, TargetNullValue=Select a display in settings}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Text="{Binding Hotkey.DisplayText}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <Button Margin="0,0,8,8"
                                                Padding="12,6"
                                                Click="ToggleMonitorNodeCaptureButton_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Content" Value="Start Clipping" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                            <Setter Property="Content" Value="Stop Clipping" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Margin="0,0,0,8"
                                                Padding="12,6"
                                                IsEnabled="{Binding CanSaveClip}"
                                                Click="SaveMonitorNodeButton_Click"
                                                Content="Save Clip" />
                                    </WrapPanel>
                                    <TextBlock Margin="0,10,0,0" Text="{Binding Status}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Border Grid.Row="7"
                    Padding="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushDark}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Style="{StaticResource ShowOnCaptureTabStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="352" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            VerticalAlignment="Top"
                            Padding="8,6,8,8"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource BorderBrushDark}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="0,0,0,4" LastChildFill="False">
                                <TextBlock VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold" Text="Clip Library" />
                            </DockPanel>

                            <Grid Grid.Row="1"
                                  MinHeight="164">
                                <ListBox x:Name="ClipListBox"
                                         MaxHeight="420"
                                         ItemsSource="{Binding ClipLibrary}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="False"
                                         SelectionChanged="ClipListBox_SelectionChanged">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid IsItemsHost="True"
                                                         Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Margin" Value="0,0,8,8" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="ClipCardBorder"
                                                    Background="{StaticResource PanelAltBrush}"
                                                    BorderBrush="{StaticResource BorderBrushDark}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    SnapsToDevicePixels="True"
                                                    UseLayoutRounding="True">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="82" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0">
                                                        <Border Margin="1,1,1,0"
                                                                Background="{StaticResource InputBrush}"
                                                                CornerRadius="11,11,0,0"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Border CornerRadius="11,11,0,0">
                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="{Binding ThumbnailPath}"
                                                                                    Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>
                                                                <Border x:Name="ClipPreviewFallback"
                                                                        Background="#AA0B1016"
                                                                        CornerRadius="11,11,0,0">
                                                                    <StackPanel HorizontalAlignment="Center"
                                                                                VerticalAlignment="Center">
                                                                        <TextBlock HorizontalAlignment="Center"
                                                                                   FontFamily="Segoe MDL2 Assets"
                                                                                   FontSize="18"
                                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                                   Text="&#xE714;" />
                                                                        <TextBlock Margin="0,6,0,0"
                                                                                   HorizontalAlignment="Center"
                                                                                   FontSize="10"
                                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                                   Text="Generating preview" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                        </Border>

                                                        <Button Width="28"
                                                                Height="28"
                                                                Margin="0,8,8,0"
                                                                Padding="0"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Focusable="False"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Click="DeleteClipButton_Click"
                                                                Tag="{Binding FilePath}"
                                                                ToolTip="Delete this clip">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13" Text="&#xE74D;" />
                                                        </Button>
                                                    </Grid>

                                                    <Grid Grid.Row="1"
                                                          Margin="10,10,10,10">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Button x:Name="ClipTitleButton"
                                                                Style="{StaticResource ClipTitleButtonStyle}"
                                                                Click="RenameClipTitleButton_Click"
                                                                ToolTip="Rename clip">
                                                            <TextBlock TextTrimming="CharacterEllipsis">
                                                                <Run Text="{Binding FileNameWithoutExtension, Mode=OneWay}" />
                                                                <Run Text="{Binding FileExtension, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Button>

                                                        <DockPanel x:Name="ClipRenameEditor"
                                                                   Visibility="Collapsed"
                                                                   LastChildFill="False">
                                                            <TextBox MinWidth="72"
                                                                     Padding="4,2"
                                                                     VerticalContentAlignment="Center"
                                                                     Text="{Binding EditableFileName, UpdateSourceTrigger=PropertyChanged}"
                                                                     Loaded="ClipTitleRenameTextBox_Loaded"
                                                                     LostFocus="ClipTitleRenameTextBox_LostFocus"
                                                                     PreviewKeyDown="ClipTitleRenameTextBox_PreviewKeyDown" />
                                                            <TextBlock Margin="4,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding FileExtension, Mode=OneWay}" />
                                                        </DockPanel>

                                                        <TextBlock Grid.Row="1"
                                                                   Margin="0,8,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   Text="{Binding ModifiedDisplay}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Row="2"
                                                                   Margin="0,2,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   Text="{Binding FileSizeDisplay}" />
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter TargetName="ClipCardBorder" Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
                                                    <Setter TargetName="ClipCardBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter TargetName="ClipCardBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                    <Setter TargetName="ClipTitleButton" Property="Visibility" Value="Collapsed" />
                                                    <Setter TargetName="ClipRenameEditor" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HasThumbnail}" Value="True">
                                                    <Setter TargetName="ClipPreviewFallback" Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Opacity="0.6"
                                           Text="All clips will show here"
                                           Visibility="Collapsed">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ElementName=ClipListBox, Path=HasItems}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <GroupBox Header="Transform" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Style="{StaticResource InspectorLabelStyle}" Text="Rotate" />
                                        <Slider x:Name="RotationSlider" Grid.Row="0" Grid.Column="1" Minimum="-180" Maximum="180" PreviewMouseLeftButtonDown="TransformSlider_PreviewMouseLeftButtonDown" PreviewKeyDown="TransformSlider_PreviewKeyDown" ValueChanged="TransformSlider_ValueChanged" />
                                        <TextBox x:Name="RotationTextBox" Grid.Row="0" Grid.Column="2" Margin="10,0,0,0" VerticalContentAlignment="Center" LostFocus="TransformTextBox_LostFocus" PreviewKeyDown="TransformTextBox_PreviewKeyDown" />

                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Style="{StaticResource InspectorLabelStyle}" Text="Zoom" />
                                        <Slider x:Name="ScaleSlider" Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Minimum="10" Maximum="400" PreviewMouseLeftButtonDown="TransformSlider_PreviewMouseLeftButtonDown" PreviewKeyDown="TransformSlider_PreviewKeyDown" ValueChanged="TransformSlider_ValueChanged" />
                                        <TextBox x:Name="ScaleTextBox" Grid.Row="1" Grid.Column="2" Margin="10,12,0,0" VerticalContentAlignment="Center" LostFocus="TransformTextBox_LostFocus" PreviewKeyDown="TransformTextBox_PreviewKeyDown" />

                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Style="{StaticResource InspectorLabelStyle}" Text="Pos X" Visibility="Collapsed" />
                                        <Slider x:Name="PositionXSlider" Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Minimum="-3840" Maximum="3840" PreviewMouseLeftButtonDown="TransformSlider_PreviewMouseLeftButtonDown" PreviewKeyDown="TransformSlider_PreviewKeyDown" ValueChanged="TransformSlider_ValueChanged" Visibility="Collapsed" />
                                        <TextBox x:Name="PositionXTextBox" Grid.Row="2" Grid.Column="2" Margin="10,12,0,0" VerticalContentAlignment="Center" LostFocus="TransformTextBox_LostFocus" PreviewKeyDown="TransformTextBox_PreviewKeyDown" Visibility="Collapsed" />

                                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Style="{StaticResource InspectorLabelStyle}" Text="Pos Y" Visibility="Collapsed" />
                                        <Slider x:Name="PositionYSlider" Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Minimum="-2160" Maximum="2160" PreviewMouseLeftButtonDown="TransformSlider_PreviewMouseLeftButtonDown" PreviewKeyDown="TransformSlider_PreviewKeyDown" ValueChanged="TransformSlider_ValueChanged" Visibility="Collapsed" />
                                        <TextBox x:Name="PositionYTextBox" Grid.Row="3" Grid.Column="2" Margin="10,12,0,0" VerticalContentAlignment="Center" LostFocus="TransformTextBox_LostFocus" PreviewKeyDown="TransformTextBox_PreviewKeyDown" Visibility="Collapsed" />

                                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,12,8,0" VerticalAlignment="Center" Style="{StaticResource InspectorLabelStyle}" Text="Opacity" Visibility="Collapsed" />
                                        <Slider x:Name="OpacitySlider" Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Minimum="1" Maximum="100" PreviewMouseLeftButtonDown="TransformSlider_PreviewMouseLeftButtonDown" PreviewKeyDown="TransformSlider_PreviewKeyDown" ValueChanged="TransformSlider_ValueChanged" Visibility="Collapsed" />
                                        <TextBox x:Name="OpacityTextBox" Grid.Row="4" Grid.Column="2" Margin="10,12,0,0" VerticalContentAlignment="Center" LostFocus="TransformTextBox_LostFocus" PreviewKeyDown="TransformTextBox_PreviewKeyDown" Visibility="Collapsed" />

                                        <WrapPanel Grid.Row="5" Grid.ColumnSpan="3" Margin="0,14,0,0">
                                            <Button x:Name="FitToFrameButton" Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Click="FitToFrameButton_Click" Content="Fit" />
                                            <Button x:Name="FillFrameButton" Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Click="FillFrameButton_Click" Content="Fill" Visibility="Collapsed" />
                                            <Button x:Name="FlipHorizontalButton" Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Click="FlipHorizontalButton_Click" Content="Flip H" Visibility="Collapsed" />
                                            <Button x:Name="FlipVerticalButton" Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Click="FlipVerticalButton_Click" Content="Flip V" Visibility="Collapsed" />
                                            <Button x:Name="ResetTransformButton" Margin="0,0,0,8" Style="{StaticResource GhostButtonStyle}" Click="ResetTransformButton_Click" Content="Reset" />
                                        </WrapPanel>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Crop" Margin="0,12,0,0" Padding="12" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource MutedTextBrush}" Text="Use the corner or edge handles in the preview to crop precisely." TextWrapping="Wrap" />
                                        <TextBlock x:Name="CropSummaryTextBlock" Margin="0,10,0,0" Text="Crop: full frame" />
                                        <Button x:Name="ResetCropButton" Margin="0,12,0,0" Style="{StaticResource GhostButtonStyle}" Click="ResetCropButton_Click" Content="Reset Crop" />
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Segment Actions" Margin="0,12,0,0" Padding="12" Visibility="Collapsed">
                                    <WrapPanel>
                                        <Button x:Name="DuplicateSegmentButton" Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Click="DuplicateSegmentButton_Click" Content="Duplicate" />
                                        <Button x:Name="CopySegmentSettingsButton" Margin="0,0,8,8" Style="{StaticResource GhostButtonStyle}" Click="CopySegmentSettingsButton_Click" Content="Copy Settings" />
                                        <Button x:Name="PasteSegmentSettingsButton" Margin="0,0,0,8" Style="{StaticResource GhostButtonStyle}" Click="PasteSegmentSettingsButton_Click" Content="Paste Settings" />
                                    </WrapPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Margin="0,0,0,10"
                                Padding="10"
                                Background="{StaticResource SurfaceBrush}"
                                 BorderBrush="{StaticResource BorderBrushDark}"
                                 BorderThickness="1"
                                 CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Margin="0,0,12,0">
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="{Binding Editor.SelectedClipTitle}"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Editor.SelectedClipTitle}" Value="No clip selected">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ElementName=ClipListBox, Path=SelectedItem}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Grid DataContext="{Binding ElementName=ClipListBox, Path=SelectedItem}">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.Editor.SelectedClipTitle, RelativeSource={RelativeSource AncestorType=Window}}" Value="No clip selected">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <Button Click="RenameClipTitleButton_Click"
                                                ToolTip="Rename clip">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ClipTitleButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding FileNameWithoutExtension, Mode=OneWay}" />
                                                <Run Text="{Binding FileExtension, Mode=OneWay}" />
                                            </TextBlock>
                                        </Button>

                                        <DockPanel LastChildFill="False"
                                                   VerticalAlignment="Center">
                                            <DockPanel.Style>
                                                <Style TargetType="DockPanel">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DockPanel.Style>
                                            <TextBox MinWidth="120"
                                                     Padding="4,2"
                                                     VerticalContentAlignment="Center"
                                                     FontSize="16"
                                                     FontWeight="SemiBold"
                                                     Text="{Binding EditableFileName, UpdateSourceTrigger=PropertyChanged}"
                                                     Loaded="ClipTitleRenameTextBox_Loaded"
                                                     LostFocus="ClipTitleRenameTextBox_LostFocus"
                                                     PreviewKeyDown="ClipTitleRenameTextBox_PreviewKeyDown" />
                                            <TextBlock Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding FileExtension, Mode=OneWay}" />
                                        </DockPanel>
                                    </Grid>
                                </Grid>

                                <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button x:Name="SaveEditedAsNewButton"
                                            Margin="0,0,8,0"
                                            Click="SaveEditedAsNewButton_Click"
                                            Content="Save As New" />
                                    <Button x:Name="OverwriteEditedClipButton"
                                            Margin="0,0,12,0"
                                            Click="OverwriteEditedClipButton_Click"
                                            Content="Overwrite Original"
                                            ToolTip="Replace the selected clip with the edited version" />
                                    <ToggleButton x:Name="ToolCropButton"
                                                  Margin="0,0,8,0"
                                                  Style="{StaticResource EditorToolToggleButtonStyle}"
                                                  Click="EditorToolToggleButton_Click"
                                                  Tag="crop"
                                                  ToolTip="Show the crop overlay and resize handles"
                                                  Content="Crop" />
                                    <ToggleButton x:Name="ToolTransformButton"
                                                  Style="{StaticResource EditorToolToggleButtonStyle}"
                                                  Click="EditorToolToggleButton_Click"
                                                  Tag="transform"
                                                  ToolTip="Move, zoom, rotate, and flip the selected segment"
                                                  Content="Transform" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,0,0,10"
                                Padding="0"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="1"
                                CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="560" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                <Viewbox Grid.Row="0"
                                         Margin="0,0,0,8"
                                         Stretch="Uniform"
                                         StretchDirection="Both">
                                    <Grid x:Name="PreviewHost"
                                          Width="1280"
                                          Height="720"
                                          Background="Black"
                                          ClipToBounds="True"
                                          SizeChanged="PreviewHost_SizeChanged">
                                        <Canvas x:Name="PreviewOverlayCanvas"
                                                Background="Black"
                                                IsHitTestVisible="True">
                                            <Border x:Name="PreviewVideoPresenter"
                                                    Background="Black"
                                                    BorderBrush="{StaticResource BorderBrushDark}"
                                                    BorderThickness="2"
                                                    ClipToBounds="True"
                                                    CornerRadius="14"
                                                    SnapsToDevicePixels="True">
                                                <Grid x:Name="PreviewMediaHost"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Top" />
                                            </Border>

                                            <Border x:Name="TransformSelectionBorder"
                                                    Width="0"
                                                    Height="0"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="1.5"
                                                    CornerRadius="8"
                                                    Visibility="Collapsed" />
                                            <Thumb x:Name="TransformMoveThumb"
                                                   Width="0"
                                                   Height="0"
                                                   Style="{StaticResource CropMoveThumbStyle}"
                                                   Visibility="Collapsed"
                                                   DragStarted="TransformMoveThumb_DragStarted"
                                                   DragDelta="TransformMoveThumb_DragDelta" />

                                            <Canvas x:Name="CropOverlayCanvas"
                                                    Width="0"
                                                    Height="0"
                                                    Visibility="Collapsed"
                                                    ClipToBounds="False"
                                                    IsHitTestVisible="True">
                                                <Rectangle x:Name="CropShadeTop" Fill="#B010151C" Visibility="Collapsed" />
                                                <Rectangle x:Name="CropShadeLeft" Fill="#B010151C" Visibility="Collapsed" />
                                                <Rectangle x:Name="CropShadeRight" Fill="#B010151C" Visibility="Collapsed" />
                                                <Rectangle x:Name="CropShadeBottom" Fill="#B010151C" Visibility="Collapsed" />

                                                <Border x:Name="CropSelectionBorder"
                                                        Width="0"
                                                        Height="0"
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="2"
                                                        Background="#16000000"
                                                        IsHitTestVisible="False"
                                                        CornerRadius="6"
                                                        Visibility="Collapsed" />

                                                <Thumb x:Name="CropTopThumb"
                                                       Style="{StaticResource CropEdgeThumbStyle}"
                                                       Cursor="SizeNS"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropTopThumb_DragDelta" />
                                                <Thumb x:Name="CropRightThumb"
                                                       Width="10"
                                                       Height="22"
                                                       Style="{StaticResource CropEdgeThumbStyle}"
                                                       Cursor="SizeWE"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropRightThumb_DragDelta" />
                                                <Thumb x:Name="CropBottomThumb"
                                                       Style="{StaticResource CropEdgeThumbStyle}"
                                                       Cursor="SizeNS"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropBottomThumb_DragDelta" />
                                                <Thumb x:Name="CropLeftThumb"
                                                       Width="10"
                                                       Height="22"
                                                       Style="{StaticResource CropEdgeThumbStyle}"
                                                       Cursor="SizeWE"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropLeftThumb_DragDelta" />

                                                <Thumb x:Name="CropTopLeftThumb"
                                                       Style="{StaticResource CropCornerThumbStyle}"
                                                       Cursor="SizeNWSE"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropTopLeftThumb_DragDelta" />
                                                <Thumb x:Name="CropTopRightThumb"
                                                       Style="{StaticResource CropCornerThumbStyle}"
                                                       Cursor="SizeNESW"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropTopRightThumb_DragDelta" />
                                                <Thumb x:Name="CropBottomLeftThumb"
                                                       Style="{StaticResource CropCornerThumbStyle}"
                                                       Cursor="SizeNESW"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropBottomLeftThumb_DragDelta" />
                                                <Thumb x:Name="CropBottomRightThumb"
                                                       Style="{StaticResource CropCornerThumbStyle}"
                                                       Cursor="SizeNWSE"
                                                       Visibility="Collapsed"
                                                       DragStarted="EditorMutationThumb_DragStarted"
                                                       DragDelta="CropBottomRightThumb_DragDelta" />
                                            </Canvas>

                                        </Canvas>

                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"
                                                   FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   Opacity="0.38"
                                                   Text="Select clip from the clips library"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Editor.SelectedClipTitle}" Value="No clip selected">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Viewbox>

                                    <DockPanel Grid.Row="1"
                                               Margin="12,-32,12,4"
                                               LastChildFill="False">
                                    <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <Button x:Name="PlayPreviewButton" MinWidth="112" Height="46" Margin="0,0,10,0" Padding="18,0" FontSize="15" Style="{StaticResource GhostButtonStyle}" Click="PlayPreviewButton_Click" ToolTip="Play preview">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="PlayPreviewButtonGlyph"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="18"
                                                           Text="&#xE768;" />
                                                <TextBlock x:Name="PlayPreviewButtonLabel"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"
                                                           Text="Play" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="StepBackButton" Margin="0,0,8,0" Style="{StaticResource GhostButtonStyle}" Click="StepBackButton_Click" Content="Prev Frame" Visibility="Collapsed" />
                                        <Button x:Name="StepForwardButton" Style="{StaticResource GhostButtonStyle}" Click="StepForwardButton_Click" Content="Next Frame" Visibility="Collapsed" />
                                    </WrapPanel>

                                    <TextBlock x:Name="TimelinePositionTextBlock"
                                               DockPanel.Dock="Right"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"
                                               Text="0.00s / 0.00s" />
                                </DockPanel>

                                    <ScrollViewer x:Name="TimelineScrollViewer"
                                                  Grid.Row="2"
                                                  Margin="12,2,12,8"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  ScrollChanged="TimelineScrollViewer_ScrollChanged">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource TimelineHorizontalScrollBarStyle}" />
                                        </ScrollViewer.Resources>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="28" />
                                                <RowDefinition Height="110" />
                                            </Grid.RowDefinitions>

                                            <Canvas x:Name="TimelineRulerCanvas" Grid.Row="0" Height="28" Background="Transparent" />

                                            <Grid Grid.Row="1">
                                                <Canvas x:Name="TimelineCanvas" Height="110" Background="Transparent" Panel.ZIndex="1" SizeChanged="TimelineCanvas_SizeChanged" MouseLeftButtonDown="TimelineCanvas_MouseLeftButtonDown">
                                                    <Rectangle x:Name="TimelineTrackRectangle" RadiusX="5" RadiusY="5" Height="10" Fill="{StaticResource PanelAltBrush}" />
                                                    <Rectangle x:Name="TrimSelectionRectangle" RadiusX="6" RadiusY="6" Height="10" Fill="{StaticResource AccentMutedBrush}" />
                                                </Canvas>
                                                <Canvas x:Name="TimelineSegmentsCanvas" Height="110" Background="Transparent" Panel.ZIndex="2" IsHitTestVisible="True" SizeChanged="TimelineCanvas_SizeChanged" MouseLeftButtonDown="TimelineCanvas_MouseLeftButtonDown" />
                                                <Canvas x:Name="TimelineOverlayCanvas" Height="110" Background="Transparent" Panel.ZIndex="3" SizeChanged="TimelineCanvas_SizeChanged" MouseLeftButtonDown="TimelineCanvas_MouseLeftButtonDown">
                                                    <Rectangle x:Name="TimelineDropIndicator" Width="3" Height="92" RadiusX="1.5" RadiusY="1.5" Fill="{StaticResource AccentBrush}" Visibility="Collapsed" Panel.ZIndex="0" />
                                                    <Rectangle x:Name="PlayheadLine" Width="2" Height="70" Fill="{StaticResource AccentBrush}" Panel.ZIndex="1" />
                                                    <Thumb x:Name="TrimStartThumb"
                                                           Style="{StaticResource EditorHandleThumbStyle}"
                                                           DragDelta="TrimStartThumb_DragDelta"
                                                           Visibility="Collapsed"
                                                           IsHitTestVisible="False"
                                                           Panel.ZIndex="1" />
                                                    <Thumb x:Name="TrimEndThumb"
                                                           Style="{StaticResource EditorHandleThumbStyle}"
                                                           DragDelta="TrimEndThumb_DragDelta"
                                                           Visibility="Collapsed"
                                                           IsHitTestVisible="False"
                                                           Panel.ZIndex="1" />
                                                    <Thumb x:Name="PlayheadThumb" Style="{StaticResource PlayheadThumbStyle}" DragDelta="PlayheadThumb_DragDelta" Panel.ZIndex="2" />
                                                </Canvas>
                                            </Grid>
                                        </Grid>
                                    </ScrollViewer>

                                    <WrapPanel Grid.Row="3" Margin="12,-6,12,12">
                                        <CheckBox Margin="0,0,12,0" VerticalAlignment="Center" Style="{StaticResource EditorSnapToggleStyle}" IsChecked="{Binding Editor.IsSnappingEnabled}" Content="Snap" />
                                        <StackPanel Margin="0,0,8,0">
                                            <Button x:Name="SplitSegmentButton" MinWidth="86" Style="{StaticResource GhostButtonStyle}" Click="SplitSegmentButton_Click" Content="Split" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="X" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Button x:Name="CopySegmentButton" MinWidth="86" Style="{StaticResource GhostButtonStyle}" Click="CopySegmentButton_Click" Content="Copy" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="C" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,0">
                                            <Button x:Name="PasteSegmentButton" MinWidth="96" Style="{StaticResource GhostButtonStyle}" Click="PasteSegmentButton_Click" Content="Paste After" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="V" />
                                        </StackPanel>
                                        <StackPanel>
                                            <Button x:Name="DeleteSegmentButton" MinWidth="86" Style="{StaticResource GhostButtonStyle}" Click="DeleteSegmentButton_Click" Content="Delete" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Text="Del" />
                                        </StackPanel>
                                    </WrapPanel>

                                    <TextBlock x:Name="TrimRangeTextBlock"
                                               Grid.Row="3"
                                               Margin="0,2,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Visibility="Collapsed"
                                               Text="Trim: 0.00s to 0.00s" />
                                </Grid>
                        </Border>

                    </Grid>
                </Grid>
            </Border>
                </Grid>
            </ScrollViewer>

            <Grid Grid.RowSpan="2"
                  Panel.ZIndex="20"
                  Background="#B80A0F14"
                  IsHitTestVisible="True">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUpdateOverlayVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Border Margin="28"
                        Padding="34,28"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#D0151B22"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"
                        CornerRadius="18"
                        MaxWidth="420">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Width="64"
                              Height="64"
                              Margin="0,0,0,18"
                              Style="{StaticResource UpdateOverlaySpinnerPanelStyle}">
                            <Grid.RenderTransform>
                                <RotateTransform />
                            </Grid.RenderTransform>
                            <Grid.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                             From="0"
                                                             To="360"
                                                             Duration="0:0:1.05" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Grid.Triggers>
                            <Ellipse Stroke="#33FFFFFF"
                                     StrokeThickness="4" />
                            <Ellipse Stroke="White"
                                     StrokeThickness="4"
                                     StrokeDashArray="2.4 6.2"
                                     StrokeDashCap="Round" />
                        </Grid>

                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding UpdateOverlayText}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#CCFFFFFF"
                                   Text="A new DualClip version is ready when you are."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanShowUpdateOverlaySpinner}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel Margin="0,24,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource UpdateOverlayActionPanelStyle}">
                            <Button MinWidth="126"
                                    Margin="0,0,12,0"
                                    Click="UpdateNowButton_Click"
                                    Content="Update Now" />
                            <Button MinWidth="126"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Click="UpdateLaterButton_Click"
                                    Content="Update Later" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
